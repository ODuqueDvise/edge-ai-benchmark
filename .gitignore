__pycache__/
*.pyc
.venv/
venv/

# Datasets: cada equipo descarga el suyo (se verifica por conteo/variante), no se versiona.
datasets/

# Modelos: no versionar pesos arbitrarios. El modelo canonico se fuerza con:
#   git add -f models/cnn_baseline.onnx
models/*
!models/.gitkeep

# Los RESULTADOS crudos SI se versionan: son la traza auditable del proyecto (OE3).
# (results/*.json y results/*.csv quedan trazados a proposito.)

# RESULTS_LOG.md es un resumen GENERADO (scripts/build_results_log.py) desde los JSON.
# No se versiona: evita conflictos entre maquinas. Se regenera localmente cuando se quiera ver.
results/RESULTS_LOG.md
