__pycache__/
*.pyc
.venv/
venv/

# Datasets: cada equipo descarga el suyo (se verifica por conteo/variante), no se versiona.
datasets/

# Modelos: se versionan TODOS los ONNX <100MB (baselines pequenos, INT8, podados, KD) y
# las listas de calibracion. EXCEPCIONES: el baseline ResNet-50 FP32 (~102MB) supera el
# limite duro de 100MB de GitHub y es regenerable con export_model.py + checksum, asi que
# NO se versiona; los ONNX temporales de cuantizacion/calibracion tampoco.
models/*
!models/.gitkeep
!models/*.onnx
!models/*.calib.txt
models/resnet50_baseline.onnx
models/*.pre.onnx
models/augmented.onnx
models/*-inferred.onnx

# Los RESULTADOS crudos SI se versionan: son la traza auditable del proyecto (OE3).
# (results/*.json y results/*.csv quedan trazados a proposito.)

# RESULTS_LOG.md es un resumen GENERADO (scripts/build_results_log.py) desde los JSON.
# No se versiona: evita conflictos entre maquinas. Se regenera localmente cuando se quiera ver.
results/RESULTS_LOG.md
